{
  "manifest_version": 3,
  "name": "RewardTrackr",
  "version": "1.0.0",
  "description": "Track and export your crypto mining rewards history to Excel for tax reporting and personal record keeping.",
  "permissions": ["cookies", "tabs", "scripting", "storage"],
  "host_permissions": [
    "https://app.gomining.com/*",
    "https://*.gomining.com/*",
    "https://josegouveia9.github.io/*"
  ],
  "icons": {
    "16": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "content_scripts": [
    {
      "matches": ["https://josegouveia9.github.io/*"],
      "js": ["scripts/contentscript.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "pages/popup.html",
    "default_title": "RewardTrackr",
    "default_icon": {
      "16": "images/logo.png",
      "48": "images/logo.png",
      "128": "images/logo.png"
    }
  }
}
