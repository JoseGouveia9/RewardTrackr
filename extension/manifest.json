{
  "manifest_version": 3,
  "name": "RewardTrackr",
  "version": "1.0.0",
  "description": "Track and export your crypto mining rewards history to Excel for tax reporting and personal record keeping.",
  "permissions": ["cookies", "tabs", "scripting"],
  "host_permissions": [
    "https://app.gomining.com/*",
    "https://*.gomining.com/*",
    "https://josegouveia9.github.io/*",
    "http://localhost/*"
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RewardTrackr",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  }
}
