    "lint": "eslint src",
    "format": "prettier --write src",
    "worker:deploy": "wrangler deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/react": "^10.45.0",
    "@tailwindcss/vite": "^4.2.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2"
  },
  "optionalDependencies": {
