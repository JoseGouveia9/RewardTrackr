{
  "name": "rewardtrackr",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package:extension:store": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$manifest = Get-Content -Raw 'extension/manifest.json' | ConvertFrom-Json; $version = $manifest.version; $date = Get-Date -Format 'yyyyMMdd'; $zipPath = 'release/RewardTrackr-extension-v' + $version + '-' + $date + '.zip'; if (-not (Test-Path 'release')) { New-Item -ItemType Directory -Path 'release' | Out-Null }; if (Test-Path $zipPath) { Remove-Item -Force $zipPath }; Compress-Archive -Path 'extension/*' -DestinationPath $zipPath -Force; Write-Output ('Created ' + $zipPath)\"",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src",
    "worker:deploy": "wrangler deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@sentry/react": "^10.47.0",
    "@tailwindcss/vite": "^4.2.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.0"
  }
}
